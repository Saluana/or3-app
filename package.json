{
    "name": "or3-app",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build --preset static",
        "build:web": "nuxt build --preset static",
        "build:mobile": "bun run build:web",
        "cap:sync": "bun run build:web && bunx cap sync",
        "cap:open:android": "bunx cap open android",
        "cap:open:ios": "bunx cap open ios",
        "dev": "nuxt dev --host 0.0.0.0 --port 3060",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "nuxt typecheck"
    },
    "dependencies": {
        "@capacitor/core": "^7.4.3",
        "@capacitor/keyboard": "^7.0.0",
        "@capgo/capacitor-native-biometric": "7.6.0",
        "@nuxt/fonts": "^0.11.4",
        "@nuxt/icon": "^1.15.0",
        "@nuxt/ui": "^4.7.0",
        "@tiptap/extension-mention": "^2.26.1",
        "@tiptap/extension-placeholder": "^2.26.1",
        "@tiptap/starter-kit": "^2.26.1",
        "@tiptap/suggestion": "^2.26.1",
        "@tiptap/vue-3": "^2.26.1",
        "nuxt": "^4.4.2",
        "or3-scroll": "0.0.3",
        "streamdown-vue": "1.0.29",
        "tiptap-markdown": "^0.9.0",
        "vue": "^3.5.32",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@capacitor/android": "^7.4.3",
        "@capacitor/cli": "^7.4.3",
        "@capacitor/ios": "^7.4.3",
        "@vue/test-utils": "^2.4.8",
        "happy-dom": "^20.9.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.7"
    }
}
