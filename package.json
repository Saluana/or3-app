{
  "name": "or3-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build --preset static",
    "build:web": "nuxt build --preset static",
    "build:mobile": "bun run build:web",
    "cap:sync": "bun run build:web && bunx cap sync",
    "cap:open:android": "bunx cap open android",
    "cap:open:ios": "bunx cap open ios",
    "electron": "bun run build:web && electron electron/main.js",
    "electron:dev": "bun scripts/electron-dev.mjs",
    "electron:dev:raw": "OR3_ELECTRON_DEV_URL=http://127.0.0.1:3060 electron electron/main.js",
    "electron:fuses": "electron-fuses --app . --config electron/fuses.config.json",
    "validate:app-links": "node scripts/validate-app-links.mjs",
    "dev": "nuxt dev --host 0.0.0.0 --port 3060",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/core": "^7.4.3",
    "@capacitor/keyboard": "^7.0.0",
    "@capgo/capacitor-native-biometric": "7.6.0",
    "@iconify-json/lucide": "^1.2.108",
    "@iconify-json/pixelarticons": "^1.2.5",
    "@iconify-json/tabler": "^1.2.35",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/ui": "^4.7.0",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-mention": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/suggestion": "^3.22.4",
    "@tiptap/vue-3": "^3.22.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "jsqr": "^1.4.0",
    "nuxt": "^4.4.2",
    "or3-scroll": "0.0.3",
    "qrcode": "^1.5.4",
    "streamdown-vue": "1.0.29",
    "tailwindcss": "^4.2.4",
    "tiptap-markdown": "^0.9.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@electron/fuses": "^2.1.1",
    "@types/qrcode": "^1.5.6",
    "@vue/test-utils": "^2.4.8",
    "electron": "^42.1.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
